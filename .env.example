# Copy to .env for local runs (GitHub Actions uses repo secrets instead)

# From @BotFather on Telegram (see README)
TELEGRAM_BOT_TOKEN=

# Your numeric chat id (see README for how to find it)
TELEGRAM_CHAT_ID=

# Optional but recommended — free key from https://dev.pokemontcg.io
# Without it you get a lower rate limit.
POKEMONTCG_API_KEY=
